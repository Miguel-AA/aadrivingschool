# Florida Driver Help Center — environment variables
# Copy to `.env.local` and fill in real values. None are required for the
# foundation build (all integrations are stubbed), but these document what the
# later phases will need.

# Public site URL (used for absolute SEO URLs / sitemap). No trailing slash.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Contact / concierge (placeholders — confirm before launch)
NEXT_PUBLIC_WHATSAPP_NUMBER=15555555555
NEXT_PUBLIC_SUPPORT_PHONE=+1-555-555-5555
NEXT_PUBLIC_SUPPORT_EMAIL=help@example.com

# --- Deferred (later phases) ---
