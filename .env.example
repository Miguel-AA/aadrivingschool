# Florida Top 1 Driving School — environment variables (floridatop1drivingschool.com)
# Copy to `.env.local` and fill in real values. None are required for the
# foundation build (all integrations are stubbed), but these document what the
# later phases will need.

# Public site URL (used for absolute SEO URLs / sitemap). No trailing slash.
NEXT_PUBLIC_SITE_URL=https://floridatop1drivingschool.com

# Contact / concierge (placeholders — confirm before launch)
NEXT_PUBLIC_WHATSAPP_NUMBER=15555555555
NEXT_PUBLIC_SUPPORT_PHONE=+1-555-555-5555
NEXT_PUBLIC_SUPPORT_EMAIL=help@example.com

# Internal admin lead dashboard (/admin). When set, view leads at
# /<locale>/admin?token=THIS_VALUE. Leave unset to disable the page.
# NOTE: MVP-only shared-token gate — replace with real auth before production.
ADMIN_TOKEN=

# --- Deferred (later phases) ---
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# CRM_API_KEY=
# EMAIL_API_KEY=
# NEXT_PUBLIC_GA_MEASUREMENT_ID=
