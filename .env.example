# A&A Driving School — environment variables
#
# Copy to `.env.local` and fill in real values for local dev. In production,
# set these in Cloudflare Pages → Settings → Environment variables.
#
# IMPORTANT: Vite inlines `VITE_*` vars at BUILD time, not runtime. After
# changing any value in Cloudflare Pages you must trigger a REBUILD/redeploy
# for the new value to take effect. Only vars prefixed `VITE_` are exposed to
# the app. If a var is left empty, the related contact CTA is hidden rather
# than showing a fake/broken link.

# Production canonical site URL. No trailing slash. (e.g. https://aadrivingschool.com)
VITE_SITE_URL=

# Support phone for the tel: link and footer display. (e.g. +1-561-555-0123)
VITE_SUPPORT_PHONE=

# Support email for the mailto: link and footer display. (e.g. info@aadrivingschool.com)
VITE_SUPPORT_EMAIL=

# WhatsApp number — DIGITS ONLY, including country code, no "+", spaces, or dashes.
# (e.g. 15615550123 for +1 561 555 0123)
VITE_WHATSAPP_NUMBER=

# --- Server-side only (Cloudflare Pages Function) ---
# Delivery target for the lead form (a webhook/email-relay URL that receives the
# lead JSON). Read ONLY by functions/api/lead.ts on the server — do NOT prefix
# with VITE_ and never reference it from client code. Set it in Cloudflare Pages
# → Settings → Environment variables. If it is missing, valid lead submissions
# return a non-2xx error and the form shows its error state + contact fallbacks.
LEAD_WEBHOOK_URL=
